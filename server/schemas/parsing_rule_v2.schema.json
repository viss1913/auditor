{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ParsingRuleV2",
  "type": "object",
  "required": ["rule_schema_version", "meta", "layout", "columns"],
  "properties": {
    "rule_schema_version": { "const": 2 },
    "meta": {
      "type": "object",
      "required": ["name", "source_type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "source_type": { "enum": ["excel"] },
        "sheet_name": { "type": "string" },
        "profile_hint": { "type": "string" }
      }
    },
    "layout": {
      "type": "object",
      "required": ["layout_type"],
      "properties": {
        "layout_type": {
          "enum": ["hierarchy_rows", "wide_metrics", "fixed_columns", "hierarchy_osv"]
        },
        "name_column": { "type": "integer", "minimum": 0, "default": 0 },
        "data_start_row": { "type": "integer", "minimum": 0 },
        "skip_rows": { "type": "integer", "minimum": 0 }
      }
    },
    "hierarchy": {
      "type": "object",
      "properties": {
        "leaf_rules": {
          "type": "object",
          "properties": {
            "min_name_length": { "type": "number" },
            "inventory_patterns": { "type": "array", "items": { "type": "string" } },
            "skip_name_patterns": { "type": "array", "items": { "type": "string" } }
          }
        },
        "levels": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "target": { "type": "string" },
              "depth": { "type": "integer", "minimum": 0 },
              "role": { "type": "string" },
              "patterns": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "columns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["target", "source"],
        "properties": {
          "target": { "type": "string" },
          "source": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "enum": [
                  "hierarchy_field",
                  "metric",
                  "entity_from_header",
                  "fixed_cell",
                  "osv_turnover",
                  "composite_cell"
                ]
              },
              "field": {
                "type": "string",
                "enum": [
                  "group",
                  "unit",
                  "branch",
                  "subdivision",
                  "parent_unit",
                  "path",
                  "asset_name",
                  "year",
                  "account",
                  "object_name",
                  "period_label",
                  "period_year"
                ]
              },
              "measure": { "type": "string" },
              "column": { "type": "integer", "minimum": 0 },
              "extract": {
                "type": "object",
                "properties": {
                  "pattern": { "type": "string" },
                  "group": { "type": "integer", "minimum": 0 },
                  "transform": { "type": "string", "enum": ["none", "date_ddmmyyyy"] }
                },
                "required": ["pattern"],
                "additionalProperties": true
              },
              "period_suffix": { "type": "string" }
            }
          }
        }
      }
    },
    "column_map": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "conditions": {
      "type": "object",
      "properties": {
        "debit_account": { "type": "string" },
        "credit_account": { "type": "string" },
        "date_start": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "date_end": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      }
    },
    "multi_row": {
      "type": "object",
      "properties": {
        "indicator_column": { "type": "integer" },
        "indicator_value": { "type": "string" },
        "amount_column": { "type": "integer", "minimum": 0 },
        "quantity_column": { "type": "integer", "minimum": 0 }
      }
    },
    "filters": {
      "type": "object",
      "properties": {
        "skip_row_patterns": { "type": "array", "items": { "type": "string" } }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "shape": { "enum": ["wide", "long"] },
        "operation_type": { "type": "string" }
      }
    }
  }
}
